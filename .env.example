# ===========================================
# F1 2026 Fantasy Draft - Environment Config
# ===========================================

# --- Google Sheets ---
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# OPTION 1 (Hosted/Render): Paste entire JSON as single-line string
# cat credentials.json | jq -c .
GOOGLE_SHEETS_CREDENTIALS_JSON=

# OPTION 2 (Local dev): Path to credentials file
# GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# --- OpenF1 API ---
# No API key needed! Free tier: 3 req/s, 30 req/min
F1_SEASON_YEAR=2026

# --- OpenAI API (optional validation) ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Sync Schedule ---
SYNC_INTERVAL_MINUTES=60
SYNC_LIVE_INTERVAL_SECONDS=120
SYNC_TIMEZONE=Asia/Kolkata

# --- Rate Limiting ---
# Cooldown between manual "Sync" presses (cheap incremental sync).
SYNC_COOLDOWN_SECONDS=90
# Cooldown for the expensive "Force sync" (re-fetches everything).
SYNC_FORCE_COOLDOWN_SECONDS=600

# --- Server ---
PORT=8000
LOG_LEVEL=INFO

# --- Admin ---
# Password required to trigger a Force Sync (re-fetch all + overwrite sheet).
# Leave blank for local dev; set a strong value on any public deployment.
ADMIN_PASSWORD=

# --- Dashboard ---
DASHBOARD_URL=

# --- Demo Mode ---
DEMO_GOOGLE_SHEETS_ID=
